generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(uuid())
  name             String?
  email            String             @unique
  createdAt        DateTime           @default(now())
  batch            String?
  department       String?
  division         String?
  role             Role               @default(STUDENT)
  password         String?
  adminId          String?
  linkedinUrl      String?
  mentorId         String?
  studentId        String?
  year             Int?
  accounts         Account[]
  participations   Participation[]
  postInterests    PostInterest[]
  projects         Project[]
  projectInterests ProjectInterest[]
  projectMembers   ProjectMember[]
  sessions         Session[]
  skillPosts       SkillRequestPost[]
  ledTeams         Team[]             @relation("TeamLeader")
  teamMembers      TeamMember[]
  skills           UserSkill[]
}

model Skill {
  id                 String              @id @default(uuid())
  name               String              @unique
  eventSkills        EventSkill[]
  postRequiredSkills PostRequiredSkill[]
  users              UserSkill[]
}

model UserSkill {
  id      String     @id @default(uuid())
  userId  String
  skillId String
  level   SkillLevel
  skill   Skill      @relation(fields: [skillId], references: [id])
  user    User       @relation(fields: [userId], references: [id])

  @@unique([userId, skillId])
}

model Event {
  id                 String             @id @default(uuid())
  title              String
  description        String?
  minTeamSize        Int
  maxTeamSize        Int
  createdAt          DateTime           @default(now())
  externalLink       String?
  isRegistrationOpen Boolean            @default(false)
  eventSkills        EventSkill[]
  participations     Participation[]
  skillPosts         SkillRequestPost[]
  teams              Team[]
}

model Participation {
  id        String              @id @default(uuid())
  userId    String
  eventId   String
  status    ParticipationStatus @default(INTERESTED)
  createdAt DateTime            @default(now())
  event     Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Team {
  id        String       @id @default(uuid())
  code      String       @unique
  eventId   String
  leaderId  String
  createdAt DateTime     @default(now())
  isReady   Boolean      @default(false)
  name      String?
  isLocked  Boolean      @default(false)
  event     Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leader    User         @relation("TeamLeader", fields: [leaderId], references: [id])
  members   TeamMember[]
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String
  userId String
  team   Team   @relation(fields: [teamId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model SkillRequestPost {
  id             String              @id @default(uuid())
  title          String
  description    String
  createdAt      DateTime            @default(now())
  eventId        String?
  userId         String
  interests      PostInterest[]
  requiredSkills PostRequiredSkill[]
  event          Event?              @relation(fields: [eventId], references: [id])
  user           User                @relation(fields: [userId], references: [id])
}

model PostInterest {
  id        String           @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime         @default(now())
  post      SkillRequestPost @relation(fields: [postId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model PostRequiredSkill {
  id      String           @id @default(uuid())
  postId  String
  skillId String
  post    SkillRequestPost @relation(fields: [postId], references: [id])
  skill   Skill            @relation(fields: [skillId], references: [id])
}

model Project {
  id               String            @id @default(uuid())
  title            String
  shortDescription String
  fullDescription  String?
  architecture     String?
  totalPhases      Int
  currentPhase     Int               @default(1)
  createdAt        DateTime          @default(now())
  ownerId          String
  owner            User              @relation(fields: [ownerId], references: [id])
  interests        ProjectInterest[]
  members          ProjectMember[]
}

model ProjectMember {
  id        String  @id @default(uuid())
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model ProjectInterest {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model EventSkill {
  id      String @id @default(uuid())
  eventId String
  skillId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([eventId, skillId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
}

enum SkillLevel {
  Beginner
  Intermediate
  Advanced
}

enum ParticipationStatus {
  INTERESTED
  CONFIRMED
  PENDING
}
