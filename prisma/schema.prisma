generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(uuid())
  name             String?
  email            String             @unique
  createdAt        DateTime           @default(now())
  coins            Int                @default(0)
  batch            String?
  department       String?
  division         String?
  role             Role               @default(STUDENT)
  password         String?
  adminId          String?
  linkedinUrl      String?
  githubUrl        String?
  portfolioUrl     String?
  mentorId         String?
  studentId        String?
  year             Int?
  bio              String?
  accounts         Account[]
  participations   Participation[]
  postInterests    PostInterest[]
  projects         Project[]
  projectInterests ProjectInterest[]
  projectMembers   ProjectMember[]
  sessions         Session[]
  skillPosts       SkillRequestPost[]
  ledTeams         Team[]             @relation("TeamLeader")
  teamMembers      TeamMember[]
  teamJoinRequests TeamJoinRequest[]
  skills           UserSkill[]
  avatar           Avatar?
  userItems        UserItem[]
  notifications    Notification[]
  mentorAssignments MentorMentee[]    @relation("Mentor")
  menteeAssignment MentorMentee?      @relation("Student")
  assignedTasks    Task[]
  progressLogs     ProgressLog[]
  certificates     Certificate[]
}

model Avatar {
  id        String  @id @default(cuid())
  userId    String  @unique
  base      String  @default("base_default")
  hair      String  @default("hair_default")
  outfit    String  @default("outfit_default")
  accessory String?
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarItem {
  id        String     @id @default(cuid())
  name      String
  type      String
  imageUrl  String
  price     Int
  userItems UserItem[]
}

model UserItem {
  id     String     @id @default(cuid())
  userId String
  itemId String
  item   AvatarItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model Skill {
  id                 String              @id @default(uuid())
  name               String              @unique
  eventSkills        EventSkill[]
  postRequiredSkills PostRequiredSkill[]
  users              UserSkill[]
}

model UserSkill {
  id       String     @id @default(uuid())
  userId   String
  skillId  String
  level    SkillLevel
  endorsed Boolean    @default(false)
  skill    Skill      @relation(fields: [skillId], references: [id])
  user     User       @relation(fields: [userId], references: [id])

  @@unique([userId, skillId])
}

model Event {
  id                 String             @id @default(uuid())
  title              String
  description        String?
  minTeamSize        Int
  maxTeamSize        Int
  maxParticipants    Int?
  createdAt          DateTime           @default(now())
  registrationStartDate DateTime?
  registrationEndDate DateTime?
  externalLink       String?
  posterUrl          String?
  isRegistrationOpen Boolean            @default(false)
  eventSkills        EventSkill[]
  participations     Participation[]
  skillPosts         SkillRequestPost[]
  teams              Team[]
  certificates       Certificate[]
}

model Certificate {
  id              String          @id @default(cuid())
  userId          String
  eventId         String?
  title           String
  eventName       String
  type            CertificateType
  fileUrl         String
  fileName        String
  mimeType        String
  fileSize        Int
  isSkillVibeEvent Boolean        @default(false)
  coinsAwarded    Int             @default(0)
  createdAt       DateTime        @default(now())
  event           Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Participation {
  id        String              @id @default(uuid())
  userId    String
  eventId   String
  status    ParticipationStatus @default(INTERESTED)
  createdAt DateTime            @default(now())
  event     Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Team {
  id        String       @id @default(uuid())
  code      String       @unique
  eventId   String
  leaderId  String
  createdAt DateTime     @default(now())
  isReady   Boolean      @default(false)
  name      String?
  isLocked  Boolean      @default(false)
  event     Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leader    User         @relation("TeamLeader", fields: [leaderId], references: [id])
  members   TeamMember[]
  joinRequests TeamJoinRequest[]
  project   Project?
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String
  userId String
  team   Team   @relation(fields: [teamId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model TeamJoinRequest {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model SkillRequestPost {
  id             String              @id @default(uuid())
  title          String
  description    String
  createdAt      DateTime            @default(now())
  eventId        String?
  userId         String
  interests      PostInterest[]
  requiredSkills PostRequiredSkill[]
  event          Event?              @relation(fields: [eventId], references: [id])
  user           User                @relation(fields: [userId], references: [id])
}

model PostInterest {
  id        String           @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime         @default(now())
  post      SkillRequestPost @relation(fields: [postId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model PostRequiredSkill {
  id      String           @id @default(uuid())
  postId  String
  skillId String
  post    SkillRequestPost @relation(fields: [postId], references: [id])
  skill   Skill            @relation(fields: [skillId], references: [id])
}

model Project {
  id               String            @id @default(uuid())
  title            String
  shortDescription String
  fullDescription  String?
  architecture     String?
  totalPhases      Int
  currentPhase     Int               @default(1)
  createdAt        DateTime          @default(now())
  ownerId          String
  teamId           String?           @unique
  owner            User              @relation(fields: [ownerId], references: [id])
  team             Team?             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  interests        ProjectInterest[]
  members          ProjectMember[]
  tasks            Task[]
  progressLogs     ProgressLog[]
}

model ProjectMember {
  id        String  @id @default(uuid())
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model ProjectInterest {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model EventSkill {
  id      String @id @default(uuid())
  eventId String
  skillId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([eventId, skillId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  type      String?
  requestId String?
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MentorMentee {
  id        String @id @default(cuid())
  mentorId  String
  studentId String @unique
  mentor    User   @relation("Mentor", fields: [mentorId], references: [id], onDelete: Cascade)
  student   User   @relation("Student", fields: [studentId], references: [id], onDelete: Cascade)
}

model Task {
  id          String     @id @default(uuid())
  projectId   String
  title       String
  description String?
  assignedToId String?
  status      TaskStatus @default(TODO)
  createdAt   DateTime   @default(now())
  completedAt DateTime?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo  User?      @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
}

model ProgressLog {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
}

enum SkillLevel {
  Beginner
  Intermediate
  Advanced
}

enum ParticipationStatus {
  INTERESTED
  CONFIRMED
  PENDING
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum CertificateType {
  WON
  PARTICIPATED
}
